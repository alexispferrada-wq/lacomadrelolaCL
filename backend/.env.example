# ── Servidor ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────
# Reemplaza con tu URI de MongoDB Atlas o local
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/lacomadrelola?retryWrites=true&w=majority

# ── Email (Nodemailer) ────────────────────────────────
# Usa una cuenta Gmail con "contraseña de aplicación" (App Password)
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=tu_contrasena_de_aplicacion

# Email donde recibirás las notificaciones de reservas
ADMIN_EMAIL=admin@lacomadrelola.cl

# ── CORS ──────────────────────────────────────────────
# URL del sitio frontend (GitHub Pages u otro hosting)
FRONTEND_URL=https://alexispferrada-wq.github.io

# ── Admin Panel ───────────────────────────────────────
# Credenciales básicas para el panel de administración
ADMIN_USER=admin
ADMIN_PASS=cambia_esta_contrasena_segura
